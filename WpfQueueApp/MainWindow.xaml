<Window x:Class="WpfQueueApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfQueueApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid Name="grid1" Height="70" Width="600" HorizontalAlignment="Left" Margin="12, 12, 0, 0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Label Name="lblNode1" Content="" Grid.Column="0" Height="70" HorizontalContentAlignment="Center" BorderBrush="Black" BorderThickness="1" FontWeight="Bold" FontSize="24"/>
            <Label Name="lblNode2" Content="" Grid.Column="1" Height="70" HorizontalContentAlignment="Center" BorderBrush="Black" BorderThickness="1" FontWeight="Bold" FontSize="24"/>
            <Label Name="lblNode3" Content="" Grid.Column="2" Height="70" HorizontalContentAlignment="Center" BorderBrush="Black" BorderThickness="1" FontWeight="Bold" FontSize="24"/>
            <Label Name="lblNode4" Content="" Grid.Column="3" Height="70" HorizontalContentAlignment="Center" BorderBrush="Black" BorderThickness="1" FontWeight="Bold" FontSize="24"/>
            <Label Name="lblNode5" Content="" Grid.Column="4" Height="70" HorizontalContentAlignment="Center" BorderBrush="Black" BorderThickness="1" FontWeight="Bold" FontSize="24"/>
            <Label Name="lblNode6" Content="" Grid.Column="5" Height="70" HorizontalContentAlignment="Center" BorderBrush="Black" BorderThickness="1" FontWeight="Bold" FontSize="24"/>
        </Grid>
        <Button Name="btnEnqueue" Content="Enqueue" HorizontalAlignment="Left" Height="28" Margin="76,217,0,0" VerticalAlignment="Top" Width="129" Click="btnEnqueue_Click"/>
        <Button Name="btnDequeue" Content="Dequeue" HorizontalAlignment="Left" Height="28" Margin="274,217,0,0" VerticalAlignment="Top" Width="129" Click="btnDequeue_Click"/>
        <ListBox Name="lstBox" HorizontalAlignment="Left" Height="207" Margin="498,217,0,0" VerticalAlignment="Top" Width="292" d:ItemsSource="{d:SampleData ItemCount=5}"/>
    </Grid>
</Window>
